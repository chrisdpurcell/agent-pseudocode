{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup|resume|clear|compact",
				"hooks": [
					{
						"type": "command",
						"command": "python3 \"${CLAUDE_PROJECT_DIR}/integrations/agent-hooks/apseudo-hook.py\" --host claude --event session-start",
						"timeout": 10,
						"statusMessage": "Loading pseudocode enforcement context"
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 \"${CLAUDE_PROJECT_DIR}/integrations/agent-hooks/apseudo-hook.py\" --host claude --event user-prompt-submit",
						"timeout": 10,
						"statusMessage": "Checking pseudocode prompt context"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
				"hooks": [
					{
						"type": "command",
						"command": "python3 \"${CLAUDE_PROJECT_DIR}/integrations/agent-hooks/apseudo-hook.py\" --host claude --event pre-tool-use",
						"timeout": 20,
						"statusMessage": "Checking pseudocode enforcement bypass policy"
					}
				]
			}
		],
		"PermissionRequest": [
			{
				"matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
				"hooks": [
					{
						"type": "command",
						"command": "python3 \"${CLAUDE_PROJECT_DIR}/integrations/agent-hooks/apseudo-hook.py\" --host claude --event permission-request",
						"timeout": 20,
						"statusMessage": "Checking pseudocode permission request"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit|NotebookEdit",
				"hooks": [
					{
						"type": "command",
						"command": "python3 \"${CLAUDE_PROJECT_DIR}/integrations/agent-hooks/apseudo-hook.py\" --host claude --event post-tool-use",
						"timeout": 60,
						"statusMessage": "Validating changed pseudocode"
					}
				]
			}
		],
		"SubagentStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 \"${CLAUDE_PROJECT_DIR}/integrations/agent-hooks/apseudo-hook.py\" --host claude --event subagent-stop",
						"timeout": 60,
						"statusMessage": "Checking pseudocode after subagent work"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "python3 \"${CLAUDE_PROJECT_DIR}/integrations/agent-hooks/apseudo-hook.py\" --host claude --event stop",
						"timeout": 60,
						"statusMessage": "Checking pseudocode before final response"
					}
				]
			}
		]
	}
}
