flowchart TD
    N1(["Start: review-loop"])
    N2["process amend_document(...)"]
    N3["'''Revise a document until approved, blocked, or round-capped.'''"]
    N4["round = 1"]
    N5["blockers = ()"]
    N6{"while round <= max_rounds"}
    N7["review = reviewer.review(document)"]
    N8{"if review.status == 'approved'"}
    N9["commit_final_document(document)"]
    N10(["return Accepted(reason='approved')"])
    N11{"elif review.status == 'rejected' and review.blockers"}
    N12["blockers = review.blockers"]
    N13["document = revise_using_blockers(document, blockers)"]
    N14["round += 1"]
    N15["continue"]
    N16{"else"}
    N17(["return Blocked(reason='ambiguous review result')"])
    N18(["return Blocked(reason='round cap reached', unresolved_blockers=blockers)"])
    N1 --> N2
    N2 --> N3
    N3 --> N4
    N4 --> N5
    N5 --> N6
    N6 --> N7
    N7 --> N8
    N8 --> N9
    N9 --> N10
    N10 --> N11
    N11 --> N12
    N12 --> N13
    N13 --> N14
    N14 --> N15
    N15 --> N16
    N16 --> N17
    N17 --> N18
