{
	"comments": { "lineComment": "#" },
	"brackets": [
		["(", ")"],
		["[", "]"],
		["{", "}"]
	],
	"autoClosingPairs": [
		{ "open": "(", "close": ")" },
		{ "open": "[", "close": "]" },
		{ "open": "{", "close": "}" },
		{ "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
		{ "open": "'", "close": "'", "notIn": ["string", "comment"] }
	],
	"surroundingPairs": [
		["(", ")"],
		["[", "]"],
		["{", "}"],
		["\"", "\""],
		["'", "'"]
	],
	"folding": {
		"markers": { "start": "^\\s*#\\s*region\\b", "end": "^\\s*#\\s*endregion\\b" }
	},
	"indentationRules": {
		"increaseIndentPattern": "^\\s*(process|def|if|elif|else|while|for|try|except|finally|with|match|case)\\b.*:\\s*(#.*)?$",
		"decreaseIndentPattern": "^\\s*(elif|else|except|finally|case)\\b.*:\\s*(#.*)?$"
	},
	"wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@#$%^&*()=+[{]}\\\\|;:'\\\",.<>/?\\s]+)"
}
