#!/usr/bin/env bash
set -euo pipefail

if git_root=$(git rev-parse --show-toplevel 2>/dev/null); then
  root="$git_root"
else
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  root="$(cd -- "$script_dir/.." && pwd)"
fi

export PYTHONPATH="$root/src${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m apseudo_lint "$@"
